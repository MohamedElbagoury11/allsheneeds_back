# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-here-minimum-32-chars
JWT_EXPIRES_IN=7d

# ─── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_NAME=mystore_db

# ─── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
